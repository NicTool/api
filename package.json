{
  "name": "@nictool/api",
  "version": "3.0.0-alpha.13",
  "description": "NicTool API",
  "main": "index.js",
  "type": "module",
  "files": [
    "CHANGELOG.md",
    "conf.d",
    "html",
    "lib",
    "routes",
    "sql",
    "server.js"
  ],
  "scripts": {
    "clean": "rm -rf coverage node_modules package-lock.json",
    "develop": "node --watch server.js ./server",
    "format": "npm run lint:fix && npm run prettier:fix",
    "lint": "npx eslint *.js **/*.js",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "npx prettier *.js conf.d lib routes html --check",
    "prettier:fix": "npx prettier *.js conf.d lib routes html --write",
    "server": "node ./server.js",
    "start": "node ./server.js",
    "test": "./test/run.sh",
    "test:coverage": "./test/run.sh coverage",
    "test:coverage:lcov": "./test/run.sh coverage:lcov",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update",
    "watch": "./test/run.sh watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NicTool/api.git"
  },
  "keywords": [
    "nictool",
    "api",
    "dns",
    "management"
  ],
  "author": "Matt Simerson <matt@tnpi.net>",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/NicTool/api/issues"
  },
  "homepage": "https://github.com/NicTool/api#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0"
  },
  "dependencies": {
    "@hapi/cookie": "^12.0.1",
    "@hapi/hapi": "^21.4.9",
    "@hapi/hoek": "^11.0.7",
    "@hapi/inert": "^7.1.2",
    "@hapi/jwt": "^3.2.4",
    "@hapi/vision": "^7.0.3",
    "@msimerson/hapi-openapi": "^18.0.0",
    "@nictool/dns-resource-record": "^1.8.0",
    "@nictool/validate": "^0.9.0",
    "joi": "^18.2.3",
    "mysql2": "^3.23.1",
    "qs": "^6.15.3",
    "smol-toml": "^1.7.0"
  },
  "prettier": {
    "printWidth": 110,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  }
}
